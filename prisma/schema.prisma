// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 👥 MODELO DE CLIENTES
model Customer {
  id        String    @id @default(uuid())
  name      String
  cif       String?
  phone     String?
  email     String?
  quotes    Quote[]   // Relación: Un cliente puede tener varios presupuestos
  invoices  Invoice[] // Relación: Un cliente puede tener varias facturas
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 💼 MODELO DE PRESUPUESTOS
model Quote {
  id        String      @id @default(uuid())
  name      String      // Título de la obra o proyecto
  status    String      @default("PENDING") // PENDING, ACCEPTED, REJECTED
  subtotal  Float
  taxAmount Float
  total     Float
  clientId  String
  client    Customer    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items     QuoteItem[] // Relación: Las líneas de concepto del presupuesto
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// 📦 LÍNEAS DE CONCEPTO DEL PRESUPUESTO
model QuoteItem {
  id        String   @id @default(uuid())
  concept   String
  quantity  Float
  price     Float
  taxRate   Float
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

// 📄 MODELO DE FACTURAS
model Invoice {
  id        String        @id @default(uuid())
  number    String        @unique // Número de factura (ej: FAC-2026-001)
  status    String        @default("UNPAID") // PAID, UNPAID
  subtotal  Float
  taxAmount Float
  total     Float
  clientId  String
  client    Customer      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items     InvoiceItem[] // Relación: Las líneas de concepto de la factura
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// 📦 LÍNEAS DE CONCEPTO DE LA FACTURA
model InvoiceItem {
  id        String   @id @default(uuid())
  concept   String
  quantity  Float
  price     Float
  taxRate   Float
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}